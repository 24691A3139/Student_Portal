package mits.Student_Portal_Backend;

import java.util.List;
import java.util.Optional;

import org.springframework.stereotype.Service;

@Service
public class Student_Service {
	//injecting repo class into service class
	private final Student_Repo sr;
	public Student_Service(Student_Repo  repo) {
		this.sr=repo;
	}
	//insertion -registration
	public Student register(Student stu) {
		return sr.save(stu);
	}
	//validation for login
	public Student login(String email,String password) {
		Student user=sr.findByEmail(email);
		return (user!=null && user.getPassword().equals(password))? user : null;
	}
	//retrive
	public List<Student> getAllStudents() {
		return sr.findAll();
	}
	public Optional<Student> getStudentById(Long id) {
		return sr.findById(id);
	}
	//update
	public Student updateStudent(Long id,Student s) {
		//use orelsethrow to handle exception
		Student existing =sr.findById(id).orElse(null);
		if (existing != null) {
			existing.setName(s.getName());
			existing.setEmail(s.getEmail());
			existing.setPassword(s.getPassword());
			return sr.save(existing);
		}
		return null;
	}

	//delete
	public void deleteStudent(Long id) {
		sr.deleteById(id);
	}
}
